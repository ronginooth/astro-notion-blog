---
export interface Props {
  slug: string;
  incrementView?: boolean;
}

const { slug, incrementView = false } = Astro.props;
---

<div class="post-stats" data-slug={slug} data-increment={incrementView ? 'true' : 'false'}>
  <div class="stat-item" title="閲覧数">
    <span class="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="1.35em" height="1.35em" viewBox="0 0 24 24" fill="none" class="eye-icon">
        <ellipse cx="8" cy="12" rx="4" ry="5.5" stroke="currentColor" stroke-width="2"/>
        <circle cx="9" cy="12.5" r="1.5" fill="currentColor"/>
        <ellipse cx="16" cy="12" rx="4" ry="5.5" stroke="currentColor" stroke-width="2"/>
        <circle cx="17" cy="12.5" r="1.5" fill="currentColor"/>
      </svg>
    </span>
    <span class="count stat-views">-</span>
  </div>
  <button class="stat-item like-btn" title="いいね！">
    <span class="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="0.97em" height="0.97em" viewBox="0 0 24 24" fill="none" class="heart-icon">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </span>
    <span class="count stat-likes">-</span>
  </button>
  <button class="stat-item comment-stat-btn" title="コメント">
    <span class="icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="1.1em" height="1.1em" viewBox="0 0 24 24" fill="none" class="comment-icon">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
    <span class="count stat-comments">-</span>
  </button>
</div>

<script>
  // Firebase App (the core Firebase SDK) is always required and must be listed first
  import { initializeApp } from "firebase/app";
  import { getDatabase, ref, get, set, increment } from "firebase/database";

  const firebaseConfig = {
    apiKey: "AIzaSyD4gb6Ge41lEn92C0W-UxaQIl0xjGqvSAE",
    authDomain: "astro-notion-stats.firebaseapp.com",
    projectId: "astro-notion-stats",
    storageBucket: "astro-notion-stats.firebasestorage.app",
    messagingSenderId: "380122423196",
    appId: "1:380122423196:web:b7244a1373856dc63eb259",
    databaseURL: "https://astro-notion-stats-default-rtdb.firebaseio.com"
  };

  let app, database;
  try {
    app = initializeApp(firebaseConfig);
    database = getDatabase(app);
  } catch (e) {
    console.warn("Firebase Init Error:", e);
  }

  const getStatsText = async (slug) => {
    if (!slug || !database) return { views: 0, likes: 0, commentsCount: 0 };
    const statsRef = ref(database, `stats/${slug}`);
    const snapshot = await get(statsRef);
    if (snapshot.exists()) {
      return snapshot.val();
    }
    return { views: 0, likes: 0, commentsCount: 0 };
  };

  const initStats = async () => {
    if (!database) return;
    try {
      const containers = document.querySelectorAll('.post-stats');
      for (const container of containers) {
        const slug = container.getAttribute('data-slug');
        const shouldIncrement = container.getAttribute('data-increment') === 'true';
        if (!slug) continue;

        const viewsEl = container.querySelector('.stat-views');
        const likesEl = container.querySelector('.stat-likes');
        const commentsEl = container.querySelector('.stat-comments');
        const likeBtn = container.querySelector('.like-btn');
        const commentBtn = container.querySelector('.comment-stat-btn');

        // ページビューカウントアップ（詳細ページのみ）
        if (shouldIncrement) {
          const viewedKey = `viewed_${slug}`;
          if (!sessionStorage.getItem(viewedKey)) {
            const pvRef = ref(database, `stats/${slug}/views`);
            await set(pvRef, increment(1)).catch(e => console.error("PV Error", e));
            sessionStorage.setItem(viewedKey, 'true');
          }
        }

        // 最新状態を取得して表示
        const updateStats = async () => {
          try {
            const stats = await getStatsText(slug);
            if (viewsEl) viewsEl.textContent = stats.views || 0;
            if (likesEl) likesEl.textContent = stats.likes || 0;
            if (commentsEl) commentsEl.textContent = stats.commentsCount || 0;
          } catch (e) {
            console.error("Stats Fetch Error", e);
          }
        };
        updateStats();

        // いいねボタン処理
        if (likeBtn) {
          const likedKey = `liked_${slug}`;
          if (localStorage.getItem(likedKey)) {
            likeBtn.classList.add('liked');
          }

          likeBtn.addEventListener('click', async () => {
            likeBtn.disabled = true;
            
            try {
              const likeRef = ref(database, `stats/${slug}/likes`);
              
              if (localStorage.getItem(likedKey)) {
                // いいね解除（取り消し）
                likeBtn.classList.remove('liked');
                await set(likeRef, increment(-1));
                localStorage.removeItem(likedKey);
              } else {
                // いいね追加
                likeBtn.classList.add('liked');
                await set(likeRef, increment(1));
                localStorage.setItem(likedKey, 'true');
              }
              
              await updateStats();
            } catch (e) {
              console.error("Like Error", e);
              // エラーが起きた場合は見た目を元に戻す
              if (localStorage.getItem(likedKey)) {
                likeBtn.classList.add('liked');
              } else {
                likeBtn.classList.remove('liked');
              }
            } finally {
              likeBtn.disabled = false;
            }
          });
        }

        // コメントボタン処理
        if (commentBtn) {
          commentBtn.addEventListener('click', () => {
            const commentsSection = document.getElementById('post-comments');
            if (commentsSection) {
              commentsSection.scrollIntoView({ behavior: 'smooth' });
              // 少し遅れてフォーカスを当てる
              setTimeout(() => {
                const input = commentsSection.querySelector('textarea, input[type="text"]');
                if (input) input.focus();
              }, 500);
            }
          });
        }
      }
    } catch (err) {
      console.error("[PostStats] Main process error:", err);
    }
  };

  document.addEventListener('astro:page-load', initStats);
  initStats();
</script>

<style>
  .post-stats {
    display: inline-flex;
    gap: 1.2rem;
    align-items: center;
    margin: 0.5rem 0 1rem 0;
    font-size: 0.95rem;
    color: var(--fg);
    opacity: 0.7;
    font-weight: 500;
    position: relative;
    z-index: 2;
  }
  .stat-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    line-height: 1;
  }
  .stat-item .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2em;
  }
  .stat-item .count {
    display: flex;
    align-items: center;
    line-height: 1;
  }
  .like-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
    font-weight: inherit;
    color: inherit;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.3s;
  }
  .like-btn:hover:not(:disabled) {
    transform: scale(1.15);
  }
  .like-btn.liked {
    color: #e0245e;
    opacity: 1;
  }
  .heart-icon, .eye-icon, .comment-icon {
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }
  .heart-icon, .comment-icon {
    transition: fill 0.3s ease, stroke 0.3s ease, transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .comment-stat-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: inherit;
    font-family: inherit;
    font-weight: inherit;
    color: inherit;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .comment-stat-btn:hover .comment-icon {
    transform: scale(1.15) translateY(-2px);
  }
  .like-btn.liked .heart-icon {
    fill: currentColor;
  }
  .like-btn:disabled {
    cursor: default;
  }
</style>
