---
export interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<div id="post-comments" class="comments-section" data-slug={slug}>
  <h3 class="comments-title">
    <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24" fill="none" class="comment-icon">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
    コメント (<span class="comments-count">0</span>)
  </h3>

  <div class="comments-list">
    <!-- Comments injected here -->
    <div class="loading-comments">読み込み中...</div>
  </div>

  <form class="comment-form" id="comment-form">
    <div class="form-group">
      <input type="text" id="comment-name" placeholder="名前 (省略時は匿名)" class="comment-input" maxlength="20" />
    </div>
    <div class="form-group">
      <textarea id="comment-text" placeholder="コメントを追加..." required class="comment-textarea" rows="3" maxlength="400"></textarea>
    </div>
    <div class="form-actions">
      <div class="form-message" id="form-message"></div>
      <button type="submit" class="submit-btn" title="返信する">
        <span>返信を送信</span>
      </button>
    </div>
  </form>
</div>

<script>
  import { initializeApp } from "firebase/app";
  import { getDatabase, ref, set, push, serverTimestamp, increment, onValue } from "firebase/database";

  const firebaseConfig = {
    apiKey: "AIzaSyD4gb6Ge41lEn92C0W-UxaQIl0xjGqvSAE",
    authDomain: "astro-notion-stats.firebaseapp.com",
    projectId: "astro-notion-stats",
    storageBucket: "astro-notion-stats.firebasestorage.app",
    messagingSenderId: "380122423196",
    appId: "1:380122423196:web:b7244a1373856dc63eb259",
    databaseURL: "https://astro-notion-stats-default-rtdb.firebaseio.com"
  };

  let app, database;
  try {
    app = initializeApp(firebaseConfig);
    database = getDatabase(app);
  } catch (e) {
    console.warn("Firebase Init Error:", e);
  }

  const escapeHTML = (str) => {
    return str.replace(/[&<>'"]/g, 
      tag => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;'
    }[tag] || tag));
  };

  const formatDate = (timestamp) => {
    if (!timestamp) return '';
    const date = new Date(timestamp);
    const now = new Date();
    const diff = Math.floor((now.getTime() - date.getTime()) / 1000);
    
    if (diff < 60) return `${diff}秒前`;
    if (diff < 3600) return `${Math.floor(diff / 60)}分前`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}時間前`;
    
    return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`;
  };

  const initComments = () => {
    if (!database) return;
    const containers = document.querySelectorAll('.comments-section');
    for (const container of containers) {
      const slug = container.getAttribute('data-slug');
      if (!slug) continue;

      const commentsList = container.querySelector('.comments-list');
      const form = container.querySelector('.comment-form');
      const nameInput = container.querySelector('.comment-input');
      const textInput = container.querySelector('.comment-textarea');
      const submitBtn = container.querySelector('.submit-btn');
      const formMessage = container.querySelector('.form-message');
      const countEl = container.querySelector('.comments-count');

      // コメントのリアルタイム取得
      const commentsRef = ref(database, `comments/${slug}`);
      onValue(commentsRef, (snapshot) => {
        commentsList.innerHTML = '';
        if (snapshot.exists()) {
          const comments = [];
          snapshot.forEach((child) => {
            comments.push({ id: child.key, ...child.val() });
          });
          
          comments.sort((a, b) => (a.createdAt || 0) - (b.createdAt || 0));
          
          if (countEl) countEl.textContent = comments.length;

          comments.forEach(comment => {
            const div = document.createElement('div');
            div.className = 'comment-item';
            const name = comment.name ? escapeHTML(comment.name) : '匿名';
            const text = escapeHTML(comment.text).replace(/\n/g, '<br>');
            const date = comment.createdAt ? formatDate(comment.createdAt) : '';
            
            div.innerHTML = `
              <div class="comment-avatar">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                </svg>
              </div>
              <div class="comment-content">
                <div class="comment-header">
                  <span class="comment-name">${name}</span>
                  <span class="comment-date text-sm opacity-70">${date}</span>
                </div>
                <div class="comment-text">${text}</div>
              </div>
            `;
            commentsList.appendChild(div);
          });
        } else {
          if (countEl) countEl.textContent = '0';
          commentsList.innerHTML = '<div class="no-comments">まだコメントはありません。一番乗りで返信しよう！</div>';
        }
      });

      // フォーム送信
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const lastCommentTimeKey = `last_comment_${slug}`;
          const lastCommentTime = localStorage.getItem(lastCommentTimeKey);
          const now = Date.now();
          
          if (lastCommentTime && (now - parseInt(lastCommentTime) < 60000)) {
            formMessage.textContent = '連続で投稿することはできません。1分お待ちください。';
            formMessage.className = 'form-message error';
            return;
          }

          const name = nameInput.value.trim();
          const text = textInput.value.trim();
          
          if (!text) return;
          
          submitBtn.disabled = true;
          submitBtn.querySelector('span').textContent = '送信中...';
          formMessage.textContent = '';
          
          try {
            const newCommentRef = push(commentsRef);
            await set(newCommentRef, {
              name: name,
              text: text,
              createdAt: serverTimestamp()
            });
            
            const statsRef = ref(database, `stats/${slug}/commentsCount`);
            await set(statsRef, increment(1));
            
            const topStatEl = document.querySelector(`.post-stats[data-slug="${slug}"] .stat-comments`);
            if (topStatEl) {
               const current = parseInt(topStatEl.textContent || '0');
               if (!isNaN(current)) {
                  topStatEl.textContent = current + 1;
               }
            }

            localStorage.setItem(lastCommentTimeKey, now.toString());
            
            textInput.value = '';
            formMessage.textContent = '送信しました！';
            formMessage.className = 'form-message success';
            
            setTimeout(() => {
              formMessage.textContent = '';
              formMessage.className = 'form-message';
            }, 3000);
            
          } catch (err) {
            console.error("Comment submit error:", err);
            formMessage.textContent = 'エラーが発生しました。';
            formMessage.className = 'form-message error';
          } finally {
            submitBtn.disabled = false;
            submitBtn.querySelector('span').textContent = '返信を送信';
          }
        });
      }
    }
  };

  document.addEventListener('astro:page-load', initComments);
  initComments();
</script>

<style is:global>
  .comments-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(125, 125, 125, 0.2);
    color: var(--fg);
  }
  .comments-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }
  .comments-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .comment-item {
    display: flex;
    gap: 1rem;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .comment-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--fg);
    color: var(--bg);
    opacity: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .comment-avatar svg {
    width: 24px;
    height: 24px;
    display: block;
  }
  .comment-content {
    flex: 1;
    background: rgba(125,125,125,0.05);
    padding: 1rem;
    border-radius: 8px;
    min-width: 0; /* 防止内容溢出 */
  }
  .comment-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .comment-name {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .comment-date {
    font-size: 0.8rem;
    opacity: 0.7;
  }
  .comment-text {
    font-size: 0.95rem;
    line-height: 1.6;
    word-break: break-word;
  }
  .no-comments {
    text-align: center;
    padding: 2rem 0;
    font-size: 0.9rem;
    background: rgba(125,125,125,0.05);
    border-radius: 8px;
    opacity: 0.7;
  }
  .loading-comments {
    text-align: center;
    padding: 1rem;
    opacity: 0.7;
  }
  
  /* フォームのスタイル */
  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: rgba(125,125,125,0.03);
    padding: 1.2rem;
    border-radius: 12px;
    border: 1px solid rgba(125,125,125,0.1);
  }
  .form-group {
    display: flex;
    flex-direction: column;
  }
  .comment-input, .comment-textarea {
    background: var(--bg); /* 明示的に背景色を指定 */
    border: 1px solid rgba(125,125,125,0.2);
    border-radius: 6px;
    padding: 0.8rem;
    color: var(--fg);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  .comment-input:focus, .comment-textarea:focus {
    outline: none;
    border-color: #1da1f2;
  }
  .comment-textarea {
    resize: vertical;
    min-height: 80px;
  }
  .form-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .submit-btn {
    background-color: #1da1f2;
    color: white;
    border: none;
    border-radius: 9999px;
    padding: 0.6rem 1.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background-color 0.2s, opacity 0.2s;
    margin-left: auto;
  }
  .submit-btn:hover {
    background-color: #1a91da;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .form-message {
    font-size: 0.85rem;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .form-message.error {
    color: #e0245e;
    opacity: 1;
  }
  .form-message.success {
    color: #17bf63;
    opacity: 1;
  }
</style>
